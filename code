import random
import time
import requests


class ProxyManager:
    def __init__(self, proxies):
        self.proxies = proxies
        self.failed = {}

    def get_proxy(self):
        available = [
            p for p in self.proxies
            if p not in self.failed or time.time() > self.failed[p]
        ]

        if not available:
            available = self.proxies

        return random.choice(available)

    def mark_failed(self, proxy):
        self.failed[proxy] = time.time() + 300

    def test_proxy(self, proxy):
        try:
            response = requests.get(
                "https://httpbin.org/ip",
                proxies={
                    "http": proxy,
                    "https": proxy
                },
                timeout=5
            )

            return response.status_code == 200

        except Exception:
            return False


